{
  "name": "faro-react-native-sdk",
  "version": "1.0.0-alpha.1",
  "description": "Monorepo for Grafana Faro React Native SDK",
  "license": "Apache-2.0",
  "author": "Grafana Labs",
  "homepage": "https://github.com/grafana/faro-react-native-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/grafana/faro-react-native-sdk.git"
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "main": "index.js",
  "scripts": {
    "start": "lerna run --parallel start",
    "start:demo": "cd demo && yarn start",
    "android": "cd demo && yarn android",
    "ios": "cd demo && yarn ios",
    "watch": "lerna run --parallel watch",
    "bootstrap": "lerna bootstrap",
    "build": "lerna run build",
    "prepublishOnly": "yarn build",
    "clean": "run-s 'clean:*'",
    "clean:packages": "lerna run --parallel clean",
    "clean:root": "rimraf .cache yarn-error.log",
    "quality": "run-p quality:circular-deps quality:test quality:lint",
    "quality:packages": "lerna run --parallel quality",
    "quality:test": "lerna run --parallel quality:test",
    "quality:format": "run-p quality:format:*",
    "quality:format:root": "prettier --cache --cache-location=.cache/prettier/root -w \"./**/*.{js,jsx,ts,tsx,css,scss,md,yaml,yml,json}\"",
    "quality:format:packages": "lerna run --parallel quality:format",
    "quality:lint": "run-s 'quality:lint:*'",
    "quality:lint:packages": "lerna run --parallel quality:lint",
    "quality:lint:root": "run-p 'quality:lint:root:*'",
    "quality:lint:root:markdown": "markdownlint README.md CHANGELOG.md CONTRIBUTING.md",
    "quality:lint:root:prettier": "prettier --cache --cache-location=.cache/prettier/root -c \"./**/*.{js,jsx,ts,tsx,css,scss,md,yaml,yml,json}\" \"!./{demo,packages}/**\"",
    "quality:circular-deps": "lerna run --parallel quality:circular-deps",
    "bump:version": "yarn exec lerna version",
    "git-hooks": "run-s git-hooks:*",
    "git-hooks:pre-commit": "lint-staged"
  },
  "devDependencies": {
    "@grafana/eslint-config": "9.0.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@types/jest": "30.0.0",
    "@typescript-eslint/eslint-plugin": "8.48.1",
    "@typescript-eslint/parser": "8.48.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "61.4.1",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "lerna": "9.0.3",
    "lint-staged": "16.2.7",
    "madge": "8.0.0",
    "markdownlint": "0.40.0",
    "markdownlint-cli": "0.46.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.7.4",
    "rimraf": "6.1.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "packageManager": "yarn@4.12.0"
}
